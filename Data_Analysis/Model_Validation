#figure 15; comparison of slope speeds

data_medium_slope = pd.read_csv("Raw_Data/Model_Validation/10062026_medium_slope.csv")
data_fast_slope = pd.read_csv("Raw_Data/Model_Validation/10062026_fast_slope.csv")

slopes_data = [data_slow_slope, data_medium_slope, data_fast_slope]
titles = ["Slow", "Medium", "Fast"]

i =0
#plotting
fig, ax = plt.subplots(3,3, figsize=(10,10),sharex='col',sharey = 'row',layout = 'constrained', gridspec_kw={'height_ratios': ([2,1,1])}) 
for data in slopes_data:  
    ax[0,i].plot(data["Time"], data["Real_V"], ls = '', marker = '.', label = 'FC Output')
    ax[0,i].plot(data["Time"], data["Model_V"], ls = '--', label = 'Model Prediction')
    
    ax[1,i].plot(data["Time"], data["Model_V"]-data["Real_V"], ls = '--', color = 'r', label = 'Difference')

   
    
    
    ax[2,i].plot(data["Time"], data["R"], ls = '--', color = 'g', label = 'Resistance')
    ax[2,i].set_ylim(0,110)
    ax[2,i].set_xlabel("Time (s)")
    
    ax[2,i].legend()
    
    ax[0,i].legend(fontsize = 11)
    ax[1,i].legend(fontsize = 11)
    ax[2,i].legend(fontsize = 11)
    
    ax[0,i].set_title(titles[i], fontsize = '14')
    
    if i == 0:
        ax[0,i].set_ylabel("Voltage (V)")
        ax[1,i].set_ylabel("Voltage (V)")
        ax[2,i].set_ylabel("Resistance (Ω)")  
    i+=1
plt.show()

