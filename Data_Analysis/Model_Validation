#importing libraries
import pandas as pd
import matplotlib.pyplot as plt
import numpy as np

#OCV before and after comparison; figures 8 & 9:
data_ocv1 = pd.read_csv("Raw_Data/Model_Validation/11062026_ocv_comparison_1_and_slow_slope.csv")
index = []

#cutoff based on time, filtering data wanted
cut = [6,61]

#find indices of times at cutoff
for i in range(len(data_ocv1["Time"])):
    if data_ocv1["Time"][i] > cut[0] and len(index)<1:
        index.append(i) 
    
    if data_ocv1["Time"][i] > cut[1] and len(index)<2:
        index.append(i)
        
        
#plotting near ocv
fig, ax  = plt.subplots(1,2, layout = 'constrained', figsize = (9,3), sharey = True)
ax[0].plot(data_ocv1["Time"][:index[0]], data_ocv1["Real_V"][:index[0]], ls = '', marker = '.', label = 'FC Output')
ax[0].plot(data_ocv1["Time"][:index[0]], data_ocv1["Model_V"][:index[0]], ls = '--', marker = '', label = 'Model Output')
ax[0].legend()
ax[0].set_xlabel("Time (s)")
ax[0].set_ylabel("Voltage (V)")
ax[0].set_title("Before")

ax[1].plot(data_ocv1["Time"][index[1]:], data_ocv1["Real_V"][index[1]:], ls = '', marker = '.', label = 'FC Output')
ax[1].plot(data_ocv1["Time"][index[1]:], data_ocv1["Model_V"][index[1]:], ls = '--', marker = '', label = 'Model Output')
ax[1].legend()
ax[1].set_xlabel("Time (s)")
ax[1].set_title("After")

plt.show()

