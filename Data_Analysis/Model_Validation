#Slow slope graph; figure 12 and 13
data_slope = pd.read_csv("Raw_Data/Model_Validation/11062026_ocv_comparison_1_and_slow_slope.csv")

#cutoff point, splitting slope in up and down part
cut = 35
#recording the index
ind = 0

#finding index
for i in range(len(data_slope["Time"])):
    if data_slope["Time"][i] >= cut:
        ind = i
        break

#plotting slope descent
fig, ax = plt.subplots(3,1, layout = 'constrained', figsize = (10,6), sharex = True)

ax[0].plot(data_slope["Time"][:ind], data_slope["Real_V"][:ind], marker = '.', ls = '', label = "FC Output")
ax[0].plot(data_slope["Time"][:ind], data_slope["Model_V"][:ind], marker = '', ls = '--', label = "Model Output")
ax[0].set_ylabel("Voltage (V)")
ax[0].legend()

ax[1].plot(data_slope["Time"][:ind], data_slope["Model_V"][:ind] - data_slope["Real_V"][:ind], marker = '.', ls = '', label = "difference", color = 'r')

ax[1].set_ylabel("Voltage (V)")
ax[1].legend()


ax[2].plot(data_slope["Time"][:ind], data_slope["R"][:ind], marker = '', ls = '--', label = "Resistance", color = 'g')
ax[2].set_ylabel("Resistance (Ω)")
ax[2].set_ylim(0,110)
ax[2].set_xlabel("Time (s)")
ax[2].legend()

plt.show()

#plotting ascent

fig, ax = plt.subplots(3,1, layout = 'constrained', figsize = (10,6), sharex = True)

ax[0].plot(data_slope["Time"][ind:-400], data_slope["Real_V"][ind:-400], marker = '.', ls = '', label = "FC Output")
ax[0].plot(data_slope["Time"][ind:-400], data_slope["Model_V"][ind:-400], marker = '', ls = '--', label = "Model Output")
ax[0].set_ylabel("Voltage (V)")
ax[0].legend()

ax[1].plot(data_slope["Time"][ind:-400], data_slope["Model_V"][ind:-400] - data_slope["Real_V"][ind:-400], marker = '.', ls = '', label = "difference", color = 'r')

ax[1].set_ylabel("Voltage (V)")
ax[1].legend()


ax[2].plot(data_slope["Time"][ind:-400], data_slope["R"][ind:-400], marker = '', ls = '--', label = "Resistance", color = 'g')
ax[2].set_ylabel("Resistance (Ω)")
ax[2].set_ylim(0,110)
ax[2].set_xlabel("Time (s)")
ax[2].legend()

plt.show()

