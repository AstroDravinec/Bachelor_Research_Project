#importing libraries
import board
import busio
import adafruit_ads1x15.ads1115 as ADS
from adafruit_ads1x15.analog_in import AnalogIn
import csv
import time
import adafruit_ina219
import keyboard

# Create the I2C bus
i2c = busio.I2C (board.SCL, board.SDA)

# Create the ADC object using the I2C bus
ads = ADS.ADS1115 (i2c)
#create INA219 pbject on same bus
ina219 = adafruit_ina219.INA219(i2c)

#first channel is voltage of fuel cell
V_fc = AnalogIn(ads, 0)


#list for csv
V_FC = []
I_FC = []
Time = []
i = 0
#taking data until keyboard interrupt

print("taking data. If you want to stop, press Ctrl+C")
time.sleep(3)
try:
    start = time.time()
    while True:
        now = time.time()
        I_fc = ina219.current/1000
        v = V_fc.voltage
        print(f"{v:.5f}, {I_fc:.5f}")
        V_FC.append(v)
        I_FC.append(I_fc)
        Time.append(now-start)
        time.sleep(0.05)
except KeyboardInterrupt:
    pass
    
	
time.sleep(1)
answer = input("Do you want a csv? (Y/N)")
if answer == "Y" or answer == "y":
	

    name = input("Name your csv (with .csv at the end)")

    with open(name, 'w') as data:  
        writer = csv.writer(data)
        #headings 
        writer.writerow(["Voltage", "Current", "Time"])
        #values
        for index in range(len(V_FC)):
            v = V_FC[index]
            i = I_FC[index]
            t = Time[index]
            writer.writerow([v,i,t])
        
    data.close()
else:
	print("That counts as a NO")
	time.sleep(2)
print("THE END") 